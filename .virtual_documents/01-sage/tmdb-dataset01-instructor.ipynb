# [TODO 8 정답] 배우 인지도 점수 계산 & 병합

# (1) cast_names 리스트를 행으로 펼치기
cast_exploded = df[['title', 'popularity', 'cast_names']].explode('cast_names')
cast_exploded = cast_exploded.rename(columns={'cast_names': 'cast_name'})
