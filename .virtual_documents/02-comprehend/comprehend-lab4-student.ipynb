)
axes[0,0].set_title('감성 분포')

# [0,1] 개체 유형 분포
all_ent_types = [e['type'] for r in all_results for e in r['entities']]
ent_cnt = Counter(all_ent_types)
axes[0,1].bar(ent_cnt.keys(), ent_cnt.values(), color='#3498db')
